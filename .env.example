# Copy this file to `.env` and fill in your values.
# `.env` is in .gitignore and never committed.

# --- Required ---

# Used to sign session cookies. Generate one with:
#   py -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-me-with-a-long-random-string

# --- Database ---

# SQLite (default — works out of the box, no setup needed)
DATABASE_URL=sqlite:///./dashboard.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/event_dashboard

# --- Public site URL ---
# Used in email links and Open Graph tags on shared event pages.
# In development, leave as localhost. In production, set to your real domain.
SITE_URL=http://localhost:8000
SITE_NAME=Event Dashboard

# --- Email broadcasting (optional, via Resend) ---
# Sign up at https://resend.com and create an API key.
# Free tier: 3,000 emails/month, 100/day.
RESEND_API_KEY=
EMAIL_FROM=Event Dashboard <onboarding@resend.dev>

# --- LinkedIn auto-posting (optional) ---
# See SETUP_BROADCASTS.md for how to obtain these.
LINKEDIN_ACCESS_TOKEN=
# Only needed if posting as a company page (not as yourself):
LINKEDIN_ORGANIZATION_URN=
